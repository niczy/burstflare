{
  "name": "burstflare",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsx scripts/build.mts",
    "build:web": "npm run build --workspace @burstflare/web",
    "ci": "npm run lint && npm run typecheck && npm run build && npm run build:web && npm test",
    "cf:generate": "tsx scripts/cloudflare-generate-wrangler.mts",
    "cf:generate:production": "CLOUDFLARE_ENVIRONMENT=production tsx scripts/cloudflare-generate-wrangler.mts",
    "cf:generate:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-generate-wrangler.mts",
    "cf:migrate": "tsx scripts/cloudflare-migrate.mts && tsx scripts/cloudflare-validate-schema.mts",
    "cf:migrate:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-migrate.mts && CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-validate-schema.mts",
    "cf:provision": "tsx scripts/cloudflare-provision.mts",
    "cf:provision:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-provision.mts",
    "cf:validate-schema": "tsx scripts/cloudflare-validate-schema.mts",
    "cf:validate-schema:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-validate-schema.mts",
    "cf:verify": "tsx scripts/cloudflare-verify.mts",
    "cf:verify:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/cloudflare-verify.mts",
    "dev:edge": "npm run build --workspace @burstflare/shared && tsx apps/edge/src/dev-server.ts",
    "dev:web": "npm run dev --workspace @burstflare/web",
    "deploy": "tsx scripts/deploy.mts",
    "deploy:staging": "CLOUDFLARE_ENVIRONMENT=staging tsx scripts/deploy.mts",
    "dev": "tsx scripts/dev.mts",
    "lint": "tsx scripts/lint.mts",
    "npm:cli:publish": "npm run build --workspace @burstflare/flare && npm publish --workspace apps/cli --access public --//registry.npmjs.org/:_authToken=$NPM_TOKEN",
    "npm:cli:smoke": "tsx scripts/npm-cli-smoke.mts",
    "release:validate": "tsx scripts/release-validate.mts",
    "ssh:smoke": "tsx scripts/ssh-smoke.mts",
    "ssh:smoke:live": "tsx scripts/live-ssh-smoke.mts",
    "smoke": "tsx scripts/smoke.mts",
    "typecheck": "tsc --project tsconfig.json",
    "ui:smoke": "tsx scripts/ui-smoke.mts",
    "test": "npm run build --workspace @burstflare/shared && node --import tsx/esm --test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
