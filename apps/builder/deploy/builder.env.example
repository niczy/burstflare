PORT=8788
BUILDER_HOST=0.0.0.0

# The repository prefix where the builder will push managed runtime images.
# Example:
# BUILDER_IMAGE_REPOSITORY=registry.cloudflare.com/<account>/burstflare-runtime
BUILDER_IMAGE_REPOSITORY=

# Shared bearer token. Set the same value as REMOTE_BUILD_TOKEN in the main app.
BUILDER_AUTH_TOKEN=

BUILDER_DOCKER_BIN=docker
BUILDER_PLATFORM=linux/amd64
BUILDER_PUSH=1
BUILDER_KEEP_TEMP=0
