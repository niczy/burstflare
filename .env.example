# Cloudflare account and zone
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=

# Cloudflare API token with Workers/D1/KV/R2/Queues permissions
CLOUDFLARE_API_TOKEN=

# Optional auth hardening
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Resend email delivery for email-code sign-in
RESEND_API_KEY=
# Example: BurstFlare <login@burstflare.dev>
RESEND_FROM=

# Optional remote managed-image builder
# If set, BUILD_QUEUE jobs call this HTTP endpoint to produce the final runtime
# image and digest for an instance build. The service falls back to a manifest-
# only build record when this is empty.
REMOTE_BUILD_URL=
REMOTE_BUILD_TOKEN=

# Stripe billing
# STRIPE_SECRET_KEY      – enables all billing operations: customer creation,
#                          checkout sessions, billing portal, payment method
#                          attachment (flare billing add-card), direct charges
#                          (flare billing charge), and usage invoicing.
# STRIPE_WEBHOOK_SECRET  – validates incoming Stripe webhook signatures.
#                          Required for the /api/stripe/webhook endpoint to
#                          process checkout.session.completed, invoice.paid,
#                          invoice.payment_failed, and subscription events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Per-unit billing rates (USD). Used when generating usage invoice line items.
BILLING_RATE_RUNTIME_MINUTE_USD=0.03
BILLING_RATE_STORAGE_GB_MONTH_USD=0.015

# Optional override for a prebuilt Cloudflare/ECR container image.
# If empty, the generated Wrangler config uses ./containers/session/Dockerfile
CLOUDFLARE_ENABLE_CONTAINERS=0
CLOUDFLARE_CONTAINER_IMAGE=

# Optional compatibility aliases
account_id=
zone_id=
domain=
